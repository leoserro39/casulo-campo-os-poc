{
  "openapi": "3.1.0",
  "info": {
    "title": "CASULO Agent Unified Action API",
    "version": "0.5.0",
    "description": "Manual ChatGPT Agent Actions integration pack for CASULO. Internal draft only; no production or client claim."
  },
  "servers": [
    {
      "url": "https://REPLACE_WITH_PUBLIC_ACTION_SERVER"
    }
