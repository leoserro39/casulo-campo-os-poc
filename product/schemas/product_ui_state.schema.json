{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Operational Cube Product UI State",
  "type": "object",
  "required": [
    "status",
    "active_vertical",
    "screens",
    "blocked_actions"
  ],
  "properties": {
    "status": {
      "type": "string"
    },
    "active_vertical": {
      "type": "string"
    },
    "screens": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
