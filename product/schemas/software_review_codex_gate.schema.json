{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Review and Codex Development Gate",
  "type": "object",
  "required": [
    "status",
    "decision",
    "candidate_systems",
    "blocked_actions"
  ],
  "properties": {
    "status": {
      "type": "string"
    },
    "decision": {
      "type": "string"
    },
    "candidate_systems": {
      "type": "array"
    },
    "blocked_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
