    "contract_version": {
      "type": "string"
    },
    "vertical_id": {
      "type": "string"
    },
    "vertical_name": {
      "type": "string"
    },
    "complexity": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "domains": {
      "type": "array"
    },
    "entities": {
      "type": "array"
    },
    "evidence_types": {
      "type": "array"
    },
    "gates": {
      "type": "array"
    },
    "cube": {
      "type": "object"
    },
    "expected_outputs": {
      "type": "array"
    },
    "blocked_actions": {
      "type": "array"
    }
