{
  "version": "casulo_delta_zero_hard_block_policy.v0.3",
  "hard_blocks": [
    "production_activation",
    "dataset_acceptance",
    "client_evidence_claim",
    "commercial_claim",
    "validated_model_gain_claim_without_external_evaluation",
